# oxides 1-4 individual plots (Bomdila village)
import matplotlib.pyplot as plt
import os

# --- CONFIGURATION ---
output_file_path = r"\1.svg"
os.makedirs(os.path.dirname(output_file_path), exist_ok=True)

# --- DATA ---
# Using LaTeX for subscripts: $_2$ for subscript 2, $_3$ for subscript 3
depth = [0.25, 0.5, 0.75, 1, 2, 3, 4, 5]
oxides = {
    r'SiO$_2$ wt%': [66.89, 67.12, 63.39, 65.06, 61.23, 64.05, 61.86, 62.34],
    r'Al$_2$O$_3$ wt%': [17.68, 17.7, 14.82, 16.63, 10.21, 11.24, 10.63, 11.92],
    r'Fe$_2$O$_3$ wt%': [9.89, 5.74, 2.91, 5.32, 2.29, 2.31, 2.56, 3.25],
    r'MgO wt%': [2.36, 1.29, 0.72, 1.42, 0.85, 0.61, 0.81, 0.63]
}

bedrock = {
    r'SiO$_2$ wt%': 73.34, 
    r'Al$_2$O$_3$ wt%': 14.26, 
    r'Fe$_2$O$_3$ wt%': 3.27, 
    r'MgO wt%': 0.73
}

# --- PLOTTING ---
fig, axes = plt.subplots(1, 4, figsize=(20, 14), sharey=True)
plt.subplots_adjust(wspace=0.2, top=0.82) # Adjusted top for titles

for i, (name, values) in enumerate(oxides.items()):
    ax = axes[i]
    
    # High visibility lines/markers
    ax.plot(values, depth, marker='o', color='black', markersize=12, linewidth=4)
    
    # Bedrock reference
    ax.scatter(bedrock[name], 5.8, color='blue', marker='o', s=150, label='Bedrock' if i==0 else "", zorder=5)
    ax.axhline(y=5.5, color='black', linestyle='--', linewidth=3) 
    
    # Axis formatting
    # Note: fontweight='bold' doesn't always apply to LaTeX parts, 
    # but the font size makes it very readable.
    ax.set_title(name, fontsize=26, pad=20) 
    ax.xaxis.tick_top()
    ax.xaxis.set_label_position('top')
    
    ax.tick_params(axis='both', which='major', labelsize=22, width=2, length=6)
    
    if i == 0:
        ax.set_ylabel('Depth (m)', fontsize=26)
        ax.set_ylim(6.4, 0) # Inverted Y-axis
        ax.legend(loc='lower left', fontsize=20, frameon=True, edgecolor='black')
    
    ax.grid(True, linestyle='-', alpha=0.3, linewidth=1.5)

plt.suptitle('Depth-alteration Profiles', fontsize=32, fontweight='bold', y=0.98)

# --- SAVE FILE ---
try:
    plt.savefig(output_file_path, dpi=300, bbox_inches='tight')
    print(f"Successfully saved plot to: {output_file_path}")
except Exception as e:
    print(f"Error saving file: {e}")
